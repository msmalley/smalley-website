# X/Twitter — TWO auth methods available (server auto-detects which to use)
#
# Method 1: Official API (requires credits at developer.x.com)
# Provides: posting, search, full API access
# Cost: $5 minimum prepaid credits
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
#
# Method 2: Cookie-based (free, no credits needed)
# Provides: posting, search via browser session
# Cost: free, but tokens expire periodically (re-extract from browser)
# Get them: x.com → DevTools → Application → Cookies
#   auth_token = the "auth_token" cookie value (40-char hex)
#   ct0 = the "ct0" cookie value (CSRF token, long hex string)
TWITTER_AUTH_TOKEN=
TWITTER_CSRF_TOKEN=

# LinkedIn OAuth2
# Setup:
#   1. Create app at linkedin.com/developers
#   2. Add products: "Share on LinkedIn" + "Sign In with LinkedIn using OpenID Connect"
#   3. Auth tab → add redirect URL: http://localhost:3000/callback
#   4. Copy Client ID and Client Secret here
#   5. Run: node linkedin-auth.js (opens browser, does the OAuth dance, writes token)
# Token expires after ~60 days. Re-run linkedin-auth.js to refresh.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

# LinkedIn Voyager (cookie auth — for post insights/analytics)
# Provides: engagement metrics (likes, comments, shares, reactions) on your posts
# Get them: linkedin.com → DevTools → Application → Cookies → linkedin.com
#   li_at = the "li_at" cookie value (long base64 string)
#   JSESSIONID = the "JSESSIONID" cookie value (strip surrounding quotes, just the number)
#   lidc = the "lidc" cookie value (datacenter routing)
#   bcookie = the "bcookie" cookie value (browser ID, strip surrounding quotes)
# All four are required. Tokens expire when you log out or after extended inactivity.
LINKEDIN_LI_AT=
LINKEDIN_JSESSIONID=
LINKEDIN_LIDC=
LINKEDIN_BCOOKIE=
